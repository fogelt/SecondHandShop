@page "/products/{id:int}"
@using SecondHandShop.Shared.DTOs
@using SecondHandShop.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject ProductService ProductService
@inject CartService CartService
@inject NavigationManager Nav

<div class="container mt-5">
    <button class="btn btn-link text-decoration-none text-dark mb-3 ps-0" @onclick='() => Nav.NavigateTo("/")'>
        <i class="bi bi-arrow-left"></i> Tillbaka till butiken
    </button>
    @if (product == null)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="row mt-2">
            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(product.ImageUrl))
                {
                    <img src="@product.ImageUrl" class="img-fluid rounded" alt="@product.Name">
                }
                else
                {
                    <div class="bg-light rounded p-5 text-center">
                        <p class="text-muted">Ingen bild tillgänglig</p>
                    </div>
                }
            </div>
            <div class="col-md-6 card shadow-lg">
                <h2 class="mt-3">@product.Name</h2>
                <p class="lead">@product.Price.ToString("C")</p>

                <div class="mb-4">
                    <div class="mt-5">
                        <h6>Beskrivning</h6>
                        <p>@product.Description</p>
                    </div>
                </div>

                <AuthorizeView Context="authContext">
                    <Authorized>
                        @if (authContext.User.IsInRole("Admin"))
                        {
                            <div class="card border-warning mb-4 shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-title fw-bold text-warning"><i class="bi bi-pencil-square"></i> Admin:
                                        Redigera produkt</h6>
                                    
                                        <EditForm Model="product" OnValidSubmit="() => HandleUpdate(product.Id, product)">
                                            <div class="mb-2">
                                                <label class="small fw-bold">Namn</label>
                                                <InputText @bind-Value="product.Name" class="form-control form-control-sm" />
                                            </div>
                                            <div class="mb-2">
                                                <label class="small fw-bold">Beskrivning</label>
                                                <InputTextArea @bind-Value="product.Description"
                                                               class="form-control form-control-sm" rows="3" />
                                            </div>
                                            <div class="row mb-3">
                                                <div class="col">
                                                    <label class="small fw-bold">Pris</label>
                                                    <InputNumber @bind-Value="product.Price" class="form-control form-control-sm" />
                                                </div>
                                                <div class="col">
                                                    <label class="small fw-bold">Bild-URL</label>
                                                    <InputText @bind-Value="product.ImageUrl"
                                                               class="form-control form-control-sm" />
                                                </div>
                                            </div>
                                            <button type="submit" class="btn btn-warning btn-sm w-100 fw-bold">Spara
                                                ändringar</button>
                                            </EditForm>
                                        </div>
                                    </div>
                                }
                            </Authorized>
                        </AuthorizeView>
                        <div class="mt-auto">
                            @if (!string.IsNullOrEmpty(message))
                            {
                                <div class="alert @messageClass py-2 text-center small animate__animated animate__fadeIn">
                                    @message
                                </div>
                            }

                            <AuthorizeView Context="authContext">
                                <Authorized>
                                    @if (authContext.User.IsInRole("User"))
                                    {
                                        <button class="btn btn-dark btn-lg w-100 mb-2 shadow-sm" @onclick="AddToCart">
                                            <i class="bi bi-cart-plus me-2"></i> Lägg i kundvagn
                                        </button>
                                    }
                                    else if (authContext.User.IsInRole("Admin"))
                                    {
                                        <div class="alert alert-light text-center border small">
                                            <i class="bi bi-info-circle me-1"></i> Du är inloggad som Admin
                                        </div>
                                    }
                                </Authorized>
                                <NotAuthorized>
                                    <button class="btn btn-outline-dark btn-lg w-100 mb-2"
                                            @onclick='() => Nav.NavigateTo("/account")'>
                                        Logga in för att handla
                                    </button>
                                </NotAuthorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            }
        </div>

@code {
    [Parameter]
    public int Id { get; set; }

    private ProductDto? product;
    private string? message;
    private string messageClass = "";

    protected override async Task OnInitializedAsync()
    {
        product = await ProductService.GetProductByIdAsync(Id);
    }

    private async Task AddToCart()
    {
        if (product != null)
        {
            bool success = await CartService.AddToCartAsync(product.Id);

            if (success)
            {
                message = "Tillagd i kundvagnen!";
                messageClass = "alert alert-success mt-4 py-2 text-center small";
            }
            else
            {
                message = "Kunde inte lägga till varan. Kontrollera inloggning.";
                messageClass = "alert alert-danger mt-4 py-2 text-center small";
            }
        }
    }

    private async Task HandleUpdate(int id, ProductDto updatedProduct)
    {
        bool success = await ProductService.UpdateProductAsync(id, updatedProduct);
        if (success)
        {
            message = "Produkt uppdaterad!";
            messageClass = "text-success";
        }
        else
        {
            message = "Kunde inte uppdatera produkten.";
            messageClass = "text-danger";
        }
    }
}