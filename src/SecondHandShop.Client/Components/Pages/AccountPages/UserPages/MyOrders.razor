@page "/my-orders"
@using SecondHandShop.Client.Services
@using SecondHandShop.Shared.DTOs
@using Microsoft.AspNetCore.Components.Authorization
@inject OrderService OrderService
@inject NavigationManager Nav

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-box-seam me-2"></i>Mina ordrar</h2>
  </div>
  <button class="btn btn-link text-decoration-none text-dark mb-3 ps-0" @onclick='() => Nav.NavigateTo("/account")'>
    <i class="bi bi-arrow-left"></i> Tillbaka
  </button>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (!orders.Any())
  {
    <div class="text-center py-5 border rounded-4 bg-light shadow-sm">
      <i class="bi bi-box-seam fs-1 text-muted"></i>
      <h4 class="mt-3 fw-bold">Inga ordrar än</h4>
      <p class="text-muted">Du har inte lagt några beställningar ännu.</p>
      <button class="btn btn-primary mt-2" @onclick='() => Nav.NavigateTo("/")'>Börja fynda</button>
    </div>
  }
  else
  {
    <div class="row g-3">
      @foreach (var order in orders)
      {
        <div class="col-12">
          <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-2">
            <div class="card-body p-4">
              <div class="row align-items-center">
                <div class="col-md-2">
                  <label class="small text-muted d-block">Ordernummer</label>
                  <span class="fw-bold">#@order.Id</span>
                </div>
                <div class="col-md-3">
                  <label class="small text-muted d-block">Datum</label>
                  <span>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</span>
                </div>
                <div class="col-md-2">
                  <label class="small text-muted d-block">Status</label>
                  @order.OrderStatus
                </div>
                <div class="col-md-2">
                  <label class="small text-muted d-block">Total</label>
                  <span class="fw-bold">@order.TotalPrice.ToString("C")</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      }
    </div>
  }
</div>

@code {
  private List<OrderDto> orders = new();
  private bool isLoading = true;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      orders = await OrderService.GetMyOrdersAsync();
    }
    finally
    {
      isLoading = false;
    }
  }
}