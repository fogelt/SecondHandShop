@page "/products/{id:int}"
@using SecondHandShop.Shared.DTOs
@using SecondHandShop.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager Nav
@inject ProductService ProductService
@inject CartService CartService

<div class="container mt-5">
    <a href="/" class="text-decoration-none text-muted small fw-medium">
        <i class="bi bi-chevron-left"></i> Tillbaka till butiken
    </a>
    @if (product == null)
    {
        <p>Laddar produkt...</p>
    }
    else
    {
        <div class="row mt-2">
            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(product.ImageUrl))
                {
                    <img src="@product.ImageUrl" class="img-fluid rounded" alt="@product.Name">
                }
                else
                {
                    <div class="bg-light rounded p-5 text-center">
                        <p class="text-muted">Ingen bild tillgänglig</p>
                    </div>
                }
            </div>
            <div class="col-md-6">
                <h2>@product.Name</h2>
                <p class="lead text-success">@product.Price.ToString("C")</p>

                <div class="card mb-4">
                    <div class="card-body">
                        <h6 class="card-title">Beskrivning</h6>
                        <p class="card-text">@product.Description</p>
                    </div>
                </div>

                <AuthorizeView>
                    <Authorized>
                        @if (context.User.IsInRole("Admin"))
                        {
                            <div class="card mb-4">
                                <div class="card-body">
                                    <h6 class="card-title">Edit:</h6>
                                    <h7>Name:</h7>
									<InputText @bind-Value=product.Name/>
                                    <h7>Description:</h7>
                                    <InputText @bind-Value=product.Description />
                                    <h7>Price:</h7>
                                    <InputNumber @bind-Value=product.Price />
                                    <button class="btn btn-primary" @onclick="() => HandleUpdate(product.Id, product)">Update</button>
                                </div>
                            </div>
                        }
                    </Authorized>
                </AuthorizeView>

                <button class="btn btn-dark btn-lg w-100 mb-2" @onclick="AddToCart">Lägg i kundvagn</button>

                @if (!string.IsNullOrEmpty(message))
                {
                    <p class="small mt-2 @messageClass">@message</p>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private ProductDto? product;
    private string? message;
    private string messageClass = "";

    protected override async Task OnInitializedAsync()
    {
        product = await ProductService.GetProductByIdAsync(Id);
    }

    private async Task AddToCart()
    {
        if (product != null)
        {
            bool success = await CartService.AddToCartAsync(product.Id);

            if (success)
            {
                message = "Tillagd i kundvagnen!";
                messageClass = "text-success";
            }
            else
            {
                message = "Kunde inte lägga till varan. Kontrollera inloggning.";
                messageClass = "text-danger";
            }
        }
    }

    private async Task HandleUpdate(int id, ProductDto updatedProduct)
    {
        bool success = await ProductService.UpdateProductAsync(id, updatedProduct);
        if (success)
        {
            message = "Produkt uppdaterad!";
            messageClass = "text-success";
        }
        else
        {
            message = "Kunde inte uppdatera produkten.";
            messageClass = "text-danger";
        }
	}
}