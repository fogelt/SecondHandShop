@page "/login"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthService AuthService
@rendermode InteractiveServer

<PageTitle>Logga in</PageTitle>

<div class="container d-flex flex-column align-items-center py-5">
  <AuthorizeView Context="auth">
    <Authorized>
      <div class="text-center">
        <h1 class="display-4 mb-4">
          Välkommen tillbaka, @(auth.User.FindFirst("firstname")?.Value ?? auth.User.Identity?.Name)!
        </h1>

        <div class="alert alert-success shadow-sm p-4">
          <p class="mb-2 text-muted">Dina aktiva roller:</p>
          @foreach (var claim in auth.User.Claims.Where(c => c.Type == "role" || c.Type == ClaimTypes.Role))
          {
            <span class="badge bg-dark fs-6 me-1">@claim.Value</span>
          }
        </div>

        <button class="btn btn-outline-danger btn-lg mt-3" @onclick="HandleLogout">
          Logga ut
        </button>
      </div>
    </Authorized>

    <NotAuthorized>
      @if (showLogin)
      {
        @* LOGIN CARD *@
        <div class="card shadow-lg border-0" style="width: 100%; max-width: 400px;">
          <div class="text-center mb-2 pt-4">
            <h2 style="letter-spacing: 4px;">LOGGA IN</h2>
          </div>
          <div class="p-4">
            <div class="mb-3">
              <label class="form-label">E-post</label>
              <input type="email" class="form-control form-control-lg" @bind="loginModel.Email" />
            </div>
            <div class="mb-4">
              <label class="form-label">Lösenord</label>
              <input type="password" class="form-control form-control-lg" @bind="loginModel.Password" />
            </div>

            <button class="btn btn-dark btn-lg w-100" @onclick="HandleLogin">
              Logga in
            </button>

            <div class="mt-3 text-center">
              <button class="btn btn-link text-decoration-none text-dark" @onclick="ToggleView">
                Inget konto? Registrera dig här
              </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
              <div class="alert alert-danger mt-4 py-2 text-center">@errorMessage</div>
            }
          </div>
        </div>
      }
      else
      {
        @* REGISTER CARD *@
        <div class="card shadow-lg border-0" style="width: 100%; max-width: 400px;">
          <div class="text-center mb-2 pt-4">
            <h2 style="letter-spacing: 4px;">REGISTRERA</h2>
          </div>
          <div class="p-4">
            <div class="mb-3">
              <label class="form-label">E-post</label>
              <input type="email" class="form-control" @bind="registerModel.Email" />
            </div>
            <div class="mb-3">
              <label class="form-label">Lösenord</label>
              <input type="password" class="form-control" @bind="registerModel.Password" />
            </div>
            <div class="row">
              <div class="col-6 mb-3">
                <label class="form-label">Förnamn</label>
                <input type="text" class="form-control" @bind="registerModel.FirstName" />
              </div>
              <div class="col-6 mb-3">
                <label class="form-label">Efternamn</label>
                <input type="text" class="form-control" @bind="registerModel.LastName" />
              </div>
            </div>

            <button class="btn btn-dark btn-lg w-100 mt-2" @onclick="HandleRegister">
              Skapa konto
            </button>

            <div class="mt-3 text-center">
              <button class="btn btn-link text-decoration-none text-dark" @onclick="ToggleView">
                Har du redan ett konto? Logga in
              </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
              <div class="alert alert-danger mt-4 py-2 text-center">@errorMessage</div>
            }
          </div>
        </div>
      }
    </NotAuthorized>
  </AuthorizeView>
</div>

@code {
  private LoginRequestDto loginModel = new();
  private RegisterRequestDto registerModel = new();
  private string? errorMessage;
  private bool showLogin = true;

  private void ToggleView()
  {
    errorMessage = null;
    showLogin = !showLogin;
  }

  private async Task HandleLogin()
  {
    errorMessage = null;
    try
    {
      var success = await AuthService.Login(loginModel);
      if (!success)
      {
        errorMessage = "Inloggningen misslyckades. Kontrollera uppgifterna.";
      }
    }
    catch (Exception ex)
    {
      errorMessage = "Ett oväntat fel uppstod vid anslutning till servern.";
      Console.WriteLine(ex.Message);
    }
  }

  private async Task HandleRegister()
  {
    errorMessage = null;
    try
    {
      var success = await AuthService.Register(registerModel);
      if (success)
      {
        // Optionally switch to login or auto-login
        showLogin = true;
        errorMessage = "Konto skapat! Vänligen logga in.";
      }
      else
      {
        errorMessage = "Registreringen misslyckades. E-posten kan redan vara upptagen.";
      }
    }
    catch (Exception ex)
    {
      errorMessage = "Ett oväntat fel uppstod vid anslutning till servern.";
      Console.WriteLine(ex.Message);
    }
  }

  private async Task HandleLogout()
  {
    await AuthService.Logout();
  }
}