@page "/about"

@rendermode InteractiveServer

<PageTitle>Om oss</PageTitle>

<div class="d-flex flex-column align-items-center min-vh-100 card shadow-lg p-5">
	<div style="max-width: 800px; text-align: center;">
		<h1 class="mb-3">Välkommen till Second Hand Shop</h1>
		<p class="text-center text-muted mb-4">Hållbart • Enkelt • Prisvärt</p>
		<hr class="mx-auto mb-5" style="width: 200px;" />


		<h2 class="mb-3">Vår idé</h2>
		<p>
			Vi tror på att ge prylar ett andra liv.
			Genom att handla second hand bidrar vi tillsammans till en mer hållbar framtid
			och minskar onödig konsumtion.
		</p>
		<h2 class="mb-3">Hur fungerar det?</h2>
		<p>
			Lägg upp en annons på några minuter, nå ut till andra användare och gör en affär direkt.
			Enkelt, snabbt och tillgängligt för alla.
		</p>
		<hr class="mb-3 mx-auto" />

