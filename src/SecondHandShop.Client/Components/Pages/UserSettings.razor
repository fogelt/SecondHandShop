@page "/user-settings"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject UserService UserService

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <a href="account" class="text-decoration-none text-muted small fw-medium">
        <i class="bi bi-chevron-left"></i> Tillbaka till konto
      </a>
      <div class="d-flex align-items-center m-2">
        <div>
          <h2 class="fw-bold mb-0"><i class="bi bi-person-gear me-2"></i>Kontoinställningar</h2>
        </div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <EditForm Model="settingsModel" OnValidSubmit="HandleUpdate">
            <DataAnnotationsValidator />

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Förnamn</label>
                <InputText @bind-Value="settingsModel.FirstName" class="form-control" placeholder="Anna" />
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Efternamn</label>
                <InputText @bind-Value="settingsModel.LastName" class="form-control" placeholder="Andersson" />
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">E-postadress</label>
              <InputText @bind-Value="settingsModel.Email" class="form-control" placeholder="namn@exempel.se" />
              <ValidationMessage For="@(() => settingsModel.Email)" class="text-danger small" />
            </div>

            <hr class="my-4 text-muted" />

            <h5 class="mb-3 text-secondary">Byt lösenord</h5>

            <div class="mb-3">
              <label class="form-label">Nytt lösenord <span class="text-muted fw-light">(valfritt)</span></label>
              <InputText type="password" @bind-Value="settingsModel.NewPassword" class="form-control" />
            </div>

            <div class="mb-4">
              <label class="form-label">Bekräfta nytt lösenord</label>
              <InputText type="password" @bind-Value="settingsModel.ConfirmPassword" class="form-control" />
              <ValidationMessage For="@(() => settingsModel.ConfirmPassword)" class="text-danger small" />
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
              <div class="alert @statusClass fade show mb-4" role="alert">
                @statusMessage
              </div>
            }

            <div class="d-grid">
              <button type="submit" class="btn btn-dark py-2" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                  <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Spara ändringar
              </button>
            </div>
          </EditForm>
        </div>
      </div>
    </div>
  </div>
</div>

@code {
  [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
  private UpdateUserDto settingsModel = new UpdateUserDto();
  private bool isSubmitting = false;
  private string? statusMessage;
  private string statusClass = "alert-success";

  protected override async Task OnInitializedAsync()
  {
    AuthenticationState? authState = await AuthStateTask;
    ClaimsPrincipal? user = authState.User;

    if (user.Identity?.IsAuthenticated == true)
    {
      settingsModel.Id = user.FindFirst("nameid")?.Value ?? "";
      settingsModel.Email = user.FindFirst("email")?.Value ?? "";
      settingsModel.FirstName = user.FindFirst("firstname")?.Value ?? "";
      settingsModel.LastName = user.FindFirst("lastname")?.Value ?? "";
    }
  }

  private async Task HandleUpdate()
  {
    isSubmitting = true;
    statusMessage = null;

    string? errorMessage = await UserService.UpdateUserAsync(settingsModel);

    if (errorMessage == null)
    {
      statusMessage = "Dina ändringar har sparats!";
      statusClass = "alert-success";
    }
    else
    {
      statusMessage = errorMessage;
      statusClass = "alert-danger";
    }

    isSubmitting = false;
  }
}