@page "/admin-users"
@using Microsoft.AspNetCore.Components.Authorization
@using SecondHandShop.Shared.DTOs
@using SecondHandShop.Client.Services

@inject UserService UserService

@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Hantera användare</PageTitle>

<AuthorizeView Roles="Admin">
  <Authorized>
    <div class="container mt-5">
      <div class="card shadow-lg p-4">
        <h2 class="text-center mb-4" style="letter-spacing: 1px;"><i class=" bi bi-people-fill"></i> ADMINISTRERA
          ANVÄNDARE</h2>

          @if (users == null)
          {
            <div class="text-center">
              <div class="spinner-border text-primary"></div>
            </div>
          }
          else
          {
            <table class="table table-hover">
              <thead class="table-dark">
                <tr>
                  <th>Namn</th>
                  <th>E-post</th>
                  <th>Roller</th>
                  <th>Ändra Roll</th>
                  <th class="text-center">Åtgärder</th>
                </tr>
              </thead>
              <tbody>
                @foreach (UserDto user in users)
                {
                  <tr>
                    <td>@user.FirstName @user.LastName</td>
                    <td>@user.Email</td>
                    <td>
                      @foreach (string role in user.Roles)
                      {
                        <span class="badge rounded-pill bg-light text-dark border px-3 py-2 me-1">
                          <i class="bi bi-shield-check me-1"></i> @role
                        </span>
                      }
                    </td>
                    <td>
                      <select class="form-select form-select-sm"
                              @onchange="@(e => HandleUpdateRole(user.Id, e.Value?.ToString()))">
                        <option value="">Välj...</option>
                        <option value="User">User</option>
                        <option value="Admin">Admin</option>
                      </select>
                    </td>
                    <td class="text-center">
                      <button class="btn btn-dark btn-sm" @onclick="() => HandleDelete(user)">
                        <i class="bi bi-trash me-1"></i>Ta bort</button>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            }
          </div>
        </div>
      </Authorized>
      <NotAuthorized>
        <RedirectToLogin />
      </NotAuthorized>
    </AuthorizeView>

@code {
  private List<UserDto>? users;

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      users = await UserService.GetAllUsers();
      StateHasChanged();
    }
  }

  private async Task HandleUpdateRole(string userId, string? role)
  {
    if (string.IsNullOrEmpty(role)) return;

    bool success = await UserService.UpdateUserRole(dto: new UpdateRoleDto { UserId = userId, NewRole = role });
    if (success) users = await UserService.GetAllUsers();
  }

  private async Task HandleDelete(UserDto user)
  {
    if (await UserService.DeleteUser(user.Id))
    {
      users?.Remove(user);
      StateHasChanged();
    }
  }
}