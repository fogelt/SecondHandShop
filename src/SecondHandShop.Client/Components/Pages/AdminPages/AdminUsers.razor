@page "/admin-users"
@using Microsoft.AspNetCore.Authorization
@using SecondHandShop.Shared.DTOs
@using SecondHandShop.Client.Services
@attribute [Authorize(Roles = "Admin")]

@inject UserService UserService
@inject IJSRuntime JS

@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Hantera användare</PageTitle>

<div class="container mt-5">
  <div class="card shadow-lg p-4">
    <h2 class="text-center mb-4"><i class="bi bi-people-fill"></i> Administrera Användare</h2>

    @if (users == null)
    {
      <div class="text-center">
        <div class="spinner-border text-primary"></div>
      </div>
    }
    else
    {
      <table class="table table-hover">
        <thead class="table-dark">
          <tr>
            <th>Namn</th>
            <th>E-post</th>
            <th>Roller</th>
            <th>Ändra Roll</th>
            <th class="text-center">Åtgärder</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var user in users)
          {
            <tr>
              <td>@user.FirstName @user.LastName</td>
              <td>@user.Email</td>
              <td>
                @foreach (var role in user.Roles)
                {
                  <span class="badge bg-info text-dark me-1">@role</span>
                }
              </td>
              <td>
                <select class="form-select form-select-sm"
                        @onchange="@(e => HandleUpdateRole(user.Id, e.Value?.ToString()))">
                  <option value="">Välj...</option>
                  <option value="User">User</option>
                  <option value="Admin">Admin</option>
                </select>
              </td>
              <td class="text-center">
                <button class="btn btn-danger btn-sm" @onclick="() => HandleDelete(user)">Ta bort</button>
              </td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>
</div>

@code {
  private List<UserDto>? users;

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      users = await AuthService.GetAllUsers();
      StateHasChanged();
    }
  }

  private async Task HandleUpdateRole(string userId, string? role)
  {
    if (string.IsNullOrEmpty(role)) return;

    var success = await UserService.UpdateUserRole(new UpdateRoleDto { UserId = userId, NewRole = role });
    if (success) users = await UserService.GetAllUsers();
  }

  private async Task HandleDelete(UserDto user)
  {
    if (await JS.InvokeAsync<bool>("confirm", $"Ta bort {user.Email}?"))
    {
      if (await UserService.DeleteUser(user.Id)) users?.Remove(user);
    }
  }
}