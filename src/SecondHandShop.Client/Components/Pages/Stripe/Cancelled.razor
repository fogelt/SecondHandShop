@page "/payment-cancelled"
@inject NavigationManager Nav

<div class="container py-5 text-center">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="p-5 bg-light rounded-4 shadow-sm">
        <i class="bi bi-cart-x text-secondary display-1 mb-3"></i>
        <h2 class="fw-bold">Betalningen avbröts</h2>
        <p class="text-muted">Inga pengar har dragits. Din varukorg finns kvar om du vill försöka igen med ett annat
          betalsätt.</p>
          <button class="btn btn-primary btn-lg w-100 rounded-pill mt-3" @onclick='() => Nav.NavigateTo("/cart")'>
            Tillbaka till varukorgen
          </button>
        </div>
      </div>
    </div>
  </div>