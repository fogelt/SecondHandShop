@page "/order-success/{SessionId}"
@using SecondHandShop.Client.Services
@using SecondHandShop.Shared.DTOs
@inject OrderService OrderService
@inject NavigationManager Nav

<div class="container py-5 mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6 text-center">
      @if (isVerifying)
      {
        <div class="spinner-border text-success mb-3" style="width: 3rem; height: 3rem;"></div>
        <h2 class="fw-bold">Bekräftar din betalning...</h2>
        <p class="text-muted">Vänligen vänta medan vi slutför din beställning. Stäng inte fönstret.</p>
      }
      else if (createdOrder != null)
      {
        <div class="card border-0 shadow-lg rounded-4 p-5 animate__animated animate__fadeIn">
          <i class="bi bi-check-circle-fill text-success display-1 mb-4"></i>
          <h1 class="fw-bold mb-2">Tack för ditt köp!</h1>
          <p class="text-muted mb-4">Din order <strong>#@createdOrder.Id</strong> är nu mottagen och vi har skickat en
            bekräftelse till din e-post.</p>
                    
            <div class="d-grid gap-2">
              <button class="btn btn-dark btn-lg rounded-pill" @onclick='() => Nav.NavigateTo("/my-orders")'>
                Se mina beställningar
              </button>
              <button class="btn btn-link text-decoration-none text-muted" @onclick='() => Nav.NavigateTo("/")'>
                Tillbaka till start
              </button>
            </div>
          </div>
        }
            else
        {
          <div class="card border-0 shadow-sm rounded-4 p-5 border-top border-danger border-5">
            <i class="bi bi-exclamation-triangle-fill text-danger display-1 mb-3"></i>
            <h2 class="fw-bold">Något gick fel</h2>
            <p class="text-muted">Vi kunde inte verifiera din betalning automatiskt. Om pengarna har dragits från ditt
              konto, vänligen kontakta vår support.</p>
              <button class="btn btn-outline-dark mt-3" @onclick='() => Nav.NavigateTo("/cart")'>
                Tillbaka till varukorgen
              </button>
            </div>
          }
        </div>
      </div>
    </div>

@code {
  [Parameter] public string SessionId { get; set; } = string.Empty;
  private bool isVerifying = true;
  private OrderDto? createdOrder;

  protected override async Task OnInitializedAsync()
  {
    createdOrder = await OrderService.ConfirmPaymentAsync(SessionId);
    isVerifying = false;
  }
}