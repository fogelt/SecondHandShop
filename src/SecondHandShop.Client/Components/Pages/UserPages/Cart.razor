@page "/cart"
@using SecondHandShop.Client.Services
@using SecondHandShop.Client.Components
@inject CartService CartService
@inject NavigationManager Nav

<div class="container mt-5">
  <h2 class="mb-4 fw-bold">Hanterar din korg</h2>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (!CartService.CartItems.Any())
  {
    <div class="text-center py-5 border rounded bg-light">
      <i class="bi bi-cart-x fs-1 text-muted"></i>
      <h4 class="mt-3">Din korg är tom</h4>
      <button class="btn btn-dark mt-3" @onclick='() => Nav.NavigateTo("/")'>Börja handla</button>
    </div>
  }
  else
  {
    <div class="row">
      <div class="col-lg-8">
        @foreach (var item in CartService.CartItems)
        {
          <CartItem Item="item" OnRemove="HandleRemove" />
        }
      </div>

      <div class="col-lg-4">
        <div class="card shadow-sm sticky-top" style="top: 20px;">
          <div class="card-body">
            <h5 class="mb-4">Sammanfattning</h5>
            <div class="d-flex justify-content-between mb-2">
              <span>Delsumma</span>
              <span>@CartService.GetTotal().ToString("C")</span>
            </div>
            <div class="d-flex justify-content-between mb-3">
              <span>Frakt</span>
              <span class="text-success">0 kr</span>
            </div>
            <hr>
            <div class="d-flex justify-content-between fw-bold fs-4 mb-4">
              <span>Totalt</span>
              <span>@CartService.GetTotal().ToString("C")</span>
            </div>
            <button class="btn btn-success btn-lg w-100 py-3 fw-bold" @onclick='() => Nav.NavigateTo("/checkout")'>
              Gå till kassan <i class="bi bi-arrow-right ms-2"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  }
</div>

@code {
  private bool isLoading = true;

  protected override async Task OnInitializedAsync()
  {
    await CartService.GetCartAsync();
    isLoading = false;
  }

  private async Task HandleRemove(int productId)
  {
    await CartService.RemoveFromCartAsync(productId);
  }
}