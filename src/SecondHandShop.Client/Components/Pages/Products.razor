@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using SecondHandShop.Shared.DTOs
@inject ProductService ProductService
@inject HttpClient Http

<div class="container mt-5 card p-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Utforska Produkter</h2>
        <span class="text-muted">@products?.Count föremål hittades</span>
    </div>

    @if (products == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Laddar produkter...</p>
        </div>
    }
    else if (products.Count == 0)
    {
        <div class="alert alert-info">Inga produkter tillgängliga just nu.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var product in products)
            {
                <div class="col">
                    <ProductCard Product="product" />
                </div>
            }
        </div>
    }
</div>

<AuthorizeView>
    <Authorized>
        @if (context.User.IsInRole("Admin"))
        {
            <div class="container mt-5 card p-5">
                <div class="card-body">
                    <h6 class="card-title">Create:</h6>
                    <h7>Name:</h7>
                    <InputText @bind-Value=newName />
                    <h7>Description:</h7>
                    <InputText @bind-Value=newDescription />
                    <h7>Image-URL:</h7>
                    <InputText @bind-Value=newImg />
                    <h7>Price:</h7>
                    <InputNumber @bind-Value=newPrice />
                    <button class="btn btn-primary" @onclick="() => HandleCreate()">Create New Product</button>
                </div>
                <div>
                    @if (!string.IsNullOrEmpty(message))
                    {
                        <p class="small mt-2 @messageClass">@message</p>
                    }
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
    private List<ProductDto>? products;
    private string newName = string.Empty;
    private string newDescription = string.Empty;
    private string newImg = string.Empty;
    private int newPrice;
    private string? message;
    private string messageClass = "";

    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.GetAllProductsAsync();
    }

    private async Task HandleCreate()
    {
        bool success = await ProductService.CreateProductAsync(new ProductDto
        {
            Name = newName,
            Description = newDescription,
            Price = newPrice,
            ImageUrl = newImg
        });

        if (success)
        {
            message = "Produkt Skapad!";
            messageClass = "text-success";
        }
        else
        {
            message = "Kunde Inte Skapa produkt!";
            messageClass = "text-danger";
        }
    }
}