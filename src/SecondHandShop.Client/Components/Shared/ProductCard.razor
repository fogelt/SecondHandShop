@using SecondHandShop.Shared.DTOs

<div class="card h-100 shadow-sm hover-shadow transition">
  @if (!string.IsNullOrEmpty(Product.ImageUrl))
  {
    <div class="img-container">
      <img src="@Product.ImageUrl" class="card-img-top" alt="@Product.Name">
    </div>
  }
  else
  {
    <div class="img-placeholder d-flex align-items-center justify-content-center bg-light">
      <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
    </div>
  }

  <div class="card-body d-flex flex-column">
    <div class="d-flex justify-content-between align-items-start mb-2">
      <h5 class="card-title mb-0 text-truncate">@Product.Name</h5>
      <span class="badge bg-dark">@Product.Price.ToString("C0")</span>
    </div>

    <p class="card-text text-muted small flex-grow-1">
      @(Product.Description?.Length > 100 ? Product.Description.Substring(0, 97) + "..." : Product.Description)
    </p>

    <div class="mt-3">
      <a href="/products/@Product.Id" class="btn btn-dark w-100 stretched-link">
        Visa detaljer
      </a>
    </div>
  </div>
</div>

<style>
  .hover-shadow:hover {
    transform: translateY(-5px);
    box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .15) !important;
  }

  .transition {
    transition: all 0.3s ease-in-out;
  }

  .img-container {
    height: 200px;
    overflow: hidden;
  }

  .img-container img {
    object-fit: cover;
    height: 100%;
    width: 100%;
  }

  .img-placeholder {
    height: 200px;
  }
</style>

@code {
  [Parameter][EditorRequired] public ProductDto Product { get; set; } = default!;
}