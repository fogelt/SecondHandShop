@using Microsoft.AspNetCore.Components.Authorization
@inject AuthService AuthService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<div class="nav-item position-relative">
  <button class="nav-link border-0 bg-transparent" @onclick="HandleClick">
    <i class="bi bi-person-circle me-1"></i> Konto
  </button>

  @if (isMenuOpen)
  {
    <div class="menu-overlay" @onclick="ToggleMenu"></div>

    <div class="dropdown-reveal-container shadow-lg border">
      <AuthorizeView>
        <Authorized>
          <div class="card d-flex flex-row align-items-center gap-3 py-3 px-3 border-0">
            <NavLink href="account" @onclick="ToggleMenu">
              <div class="position-relative">
                <img src="images/avatar-1.webp" class="rounded-circle border" width="48" height="48" alt="Avatar"
                     style="object-fit: cover;" />
              </div>
            </NavLink>

            <div class="text-start d-flex flex-column">
              <NavLink href="account" class="text-decoration-none text-dark mb-1 fw-bold" style="font-size: 0.8rem;"
                       @onclick="ToggleMenu">
                <i class="bi bi-person me-1"></i>Profil
              </NavLink>

              <NavLink href="cart" class="text-decoration-none text-dark mb-1 fw-bold" style="font-size: 0.8rem;"
                       @onclick="ToggleMenu">
                <i class="bi bi-cart me-1"></i>Kundvagn
              </NavLink>

              <button class="btn btn-link p-0 text-start small text-decoration-none fw-bold text-dark"
                      style="font-size: 0.8rem;" @onclick="HandleLogout">
                <i class="bi bi-box-arrow-right me-1"></i>Logga ut
              </button>
            </div>
          </div>
        </Authorized>
      </AuthorizeView>
    </div>
  }
</div>

@code {
  private bool isMenuOpen = false;

  private async Task HandleClick()
  {
    AuthenticationState? authState = await AuthStateProvider.GetAuthenticationStateAsync();
    System.Security.Claims.ClaimsPrincipal? user = authState.User;

    if (user.Identity is not null && user.Identity.IsAuthenticated)
    {
      ToggleMenu();
    }
    else
    {
      Nav.NavigateTo("/account");
    }
  }

  private void ToggleMenu() => isMenuOpen = !isMenuOpen;

  private async Task HandleLogout()
  {
    isMenuOpen = false;
    await AuthService.Logout();
    Nav.NavigateTo("/");
  }
}

<style>
  .dropdown-reveal-container {
    position: absolute;
    top: 100%;
    right: 0;
    z-index: 1050;
    background: white;
    min-width: 220px;
    border-radius: 12px;
    margin-top: 10px;
    overflow: hidden;
  }

  .menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1040;
    background: transparent;
  }
</style>