<div class="col-12 col-md-4 mb-2">
  <div class="card border-0 shadow-sm dashboard-card @(IsActive ? "active-tab" : "")" @onclick="OnClick">
    <div class="card-body d-flex flex-column align-items-center text-center p-3">
      <div class="icon-box mb-2">
        <i class="bi @Icon fs-4 text-dark"></i>
      </div>
      <div>
        <h6 class="fw-bold mb-0">@Title</h6>
        <p class="card-text text-muted x-small mb-0">@Description</p>
      </div>
    </div>
  </div>
</div>

@code {
  [Parameter] public string Title { get; set; } = "";
  [Parameter] public string Description { get; set; } = "";
  [Parameter] public string Icon { get; set; } = "";
  [Parameter] public bool IsActive { get; set; }
  [Parameter] public EventCallback OnClick { get; set; }
}

<style>
  .dashboard-card {
    cursor: pointer;
    transition: all 0.2s ease-in-out;
    border-radius: 12px;
    border-bottom: 4px solid transparent !important;
    height: 100%;
  }

  .dashboard-card:hover {
    background-color: #fcfcfc;
    transform: translateY(-2px);
  }

  .active-tab {
    border: 2px solid #212529 !important;
    background-color: #f8f9fa;
  }

  .icon-box {
    width: 45px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.03);
    border-radius: 50%;
  }

  .active-tab .icon-box {
    background-color: #fff;
  }

  .x-small {
    font-size: 0.7rem;
  }
</style>