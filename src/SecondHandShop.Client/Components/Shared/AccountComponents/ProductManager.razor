@using SecondHandShop.Shared.DTOs
@using SecondHandShop.Client.Services
@using System.Reflection.Metadata
@inject ProductService ProductService
@inject NavigationManager Navigation

<div class="product-management-container">
    @if (products == null)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="product-list">
            @foreach (ProductDto product in products)
            {
                <div class="card border-0 shadow-sm mb-3 rounded-3 overflow-hidden">
                    <div class="card-body p-2">
                        <div class="d-flex align-items-center justify-content-between">
                    
                            <div class="d-flex align-items-center flex-grow-1 min-w-0">
                                <img src="@product.ImageUrl" class="rounded-2 border shadow-sm me-3"
                                     style="width: 55px; height: 55px; object-fit: cover;" />
                        
                                <div class="text-truncate">
                                    <h6 class="fw-bold mb-0 text-dark">
                                        @product.Name
                                        <span class="badge bg-light text-dark border ms-2">@product.Price Kr</span>
                                    </h6>
                                    <small class="text-muted d-block text-truncate" style="max-width: 400px;">
                                        @product.Description
                                    </small>
                                </div>
                            </div>

                            <div class="d-flex gap-2 ms-3">
                                <button title="Redigera" class="btn btn-dark btn-sm rounded-circle border-0"
                                        style="width: 38px; height: 38px;" @onclick="() => HandleUpdateNav(product.Id)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                        
                                <button title="Ta bort" class="btn btn-dark btn-sm rounded-circle border-0"
                                        style="width: 38px; height: 38px;" @onclick="() => HandleDelete(product)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ProductDto>? products;

    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.GetAllProductsAsync();
    }

    private async Task HandleDelete(ProductDto product)
    {
        if (await ProductService.DeleteProductAsync(product.Id))
        {
            products?.Remove(product);
        }
    }

    private async Task HandleUpdateNav(int id)
    {
        Navigation.NavigateTo($"/products/{id}");
    }
}