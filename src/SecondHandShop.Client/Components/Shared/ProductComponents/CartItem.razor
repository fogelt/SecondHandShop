@using SecondHandShop.Shared.DTOs

<div class="card mb-3 shadow-sm border-0 bg-white">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col-md-2 col-4">
        <img src="@Item.ImageUrl" class="img-fluid rounded shadow-sm" alt="@Item.ProductName">
      </div>

      <div class="col-md-5 col-8">
        <h5 class="mb-1 fw-bold">@Item.ProductName</h5>
        <p class="text-muted small mb-0">Produkt-ID: #@Item.ProductId</p>
        <div class="d-md-none mt-2">
          <span class="fw-bold">@Item.Price.ToString("C")</span>
        </div>
      </div>

      <div class="col-md-3 d-none d-md-block text-center">
        <div class="fw-bold fs-5">@Item.Price.ToString("C")</div>
        @if (Item.Quantity > 1)
        {
          <div class="badge bg-light text-dark border">Antal: @Item.Quantity</div>
        }
      </div>

      <div class="col-md-2 col-12 text-end mt-3 mt-md-0">
        <button class="btn btn-outline-danger btn-sm px-3" @onclick="OnRemoveRequested">
          <i class="bi bi-trash me-1"></i> Ta bort
        </button>
      </div>
    </div>
  </div>
</div>

@code {
  [Parameter, EditorRequired]
  public CartItemDto Item { get; set; } = default!;

  [Parameter]
  public EventCallback<int> OnRemove { get; set; }

  private async Task OnRemoveRequested()
  {
    await OnRemove.InvokeAsync(Item.ProductId);
  }
}