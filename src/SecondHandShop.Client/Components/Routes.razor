@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    <div class="container mt-4">
                        <h1>Åtkomst nekad</h1>
                        <p>Du har inte behörighet att se denna sida eller så behöver du logga in.</p>
                        <a href="/" class="btn btn-primary">Till startsidan</a>
                    </div>
                </NotAuthorized>
                <Authorizing>
                    <p>Kontrollerar behörighet...</p>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <p role="alert">Ursäkta, vi hittade inte sidan du letade efter.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>